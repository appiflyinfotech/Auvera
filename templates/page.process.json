        "title_top": "",
        "title": "",
        "des": "<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n\n<style>\n    .jewelry-quote-container * { margin: 0; padding: 0; box-sizing: border-box; }\n\n    /* Replaced 'body' with a safe container class */\n    .jewelry-quote-container {\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;\n        background: transparent; /* Removed the beige background to blend with Shopify */\n        width: 100%;\n        padding: 0; /* Removed the unwanted side padding */\n    }\n\n    .jewelry-quote-container .form-wrapper {\n        max-width: 100%; /* Changed from 960px to 100% so it fills the screen */\n        margin: 0 auto;\n        background: #ffffff;\n        border-radius: 0px; /* Removed rounded corners so it sits perfectly flush */\n        box-shadow: none; /* Removed shadow for clean edge-to-edge look */\n        overflow: hidden;\n    }\n\n    /* ── Header ── */\n    .jewelry-quote-container .form-header {\n        background: linear-gradient(135deg, #534A43, #6e5f55);\n        padding: 46px 20px;\n        text-align: center;\n    }\n    .jewelry-quote-container .form-header h1 {\n        font-size: 2.2rem;\n        color: #EFEAE3;\n        font-weight: 500;\n        margin-bottom: 7px;\n        font-family: 'Poppins', sans-serif;\n        letter-spacing: 0.2px;\n    }\n    .jewelry-quote-container .form-header p {\n        font-size: 0.88rem;\n        color: rgba(239, 234, 227, 0.85);\n        letter-spacing: 0.3px;\n    }\n\n    /* ── Form Body ── */\n    .jewelry-quote-container form {\n        padding: 40px 60px 56px;\n        background: #ffffff;\n    }\n\n    /* ── Section Title ── */\n    .jewelry-quote-container .section-title {\n        font-size: 0.78rem;\n        color: #534A43;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.4px;\n        padding-top: 30px;\n        margin-bottom: 24px;\n        border-top: 1px solid #EFEAE3;\n    }\n    .jewelry-quote-container .section-first {\n        border-top: none;\n        padding-top: 0;\n    }\n\n    /* ── Form Layout ── */\n    .jewelry-quote-container .form-row {\n        display: grid;\n        grid-template-columns: 1fr 1fr;\n        gap: 24px;\n        margin-bottom: 24px;\n    }\n    .jewelry-quote-container .form-row.single {\n        grid-template-columns: 1fr;\n    }\n\n    /* ── Field with bold label on top ── */\n    .jewelry-quote-container .field {\n        display: flex;\n        flex-direction: column;\n        gap: 8px;\n    }\n\n    .jewelry-quote-container .field label {\n        font-size: 0.88rem;\n        font-weight: 700;\n        color: #2c2522;\n        display: flex;\n        align-items: center;\n        gap: 3px;\n    }\n\n    .jewelry-quote-container .field label .req {\n        color: #c0392b;\n        font-size: 0.9em;\n    }\n\n    .jewelry-quote-container .field input,\n    .jewelry-quote-container .field textarea,\n    .jewelry-quote-container .field select {\n        width: 100%;\n        padding: 14px 16px;\n        border: 1.5px solid #ddd8d2;\n        border-radius: 8px;\n        font-size: 0.9rem;\n        background: #faf8f6;\n        color: #534A43;\n        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;\n        appearance: none;\n        -webkit-appearance: none;\n        font-family: inherit;\n        line-height: 1.4;\n    }\n\n    .jewelry-quote-container .field input::placeholder,\n    .jewelry-quote-container .field textarea::placeholder {\n        color: #b0a89f;\n        font-weight: 400;\n    }\n\n    .jewelry-quote-container .field textarea {\n        min-height: 140px;\n        resize: vertical;\n    }\n\n    .jewelry-quote-container .field input:focus,\n    .jewelry-quote-container .field textarea:focus,\n    .jewelry-quote-container .field select:focus {\n        outline: none;\n        border-color: #534A43;\n        box-shadow: 0 0 0 3px rgba(83, 74, 67, 0.1);\n        background: #ffffff;\n    }\n\n    /* Select wrapper */\n    .jewelry-quote-container .field-select-wrap {\n        position: relative;\n    }\n    .jewelry-quote-container .field-select-wrap::after {\n        content: '▾';\n        position: absolute;\n        right: 14px;\n        top: 50%;\n        transform: translateY(-50%);\n        color: #8c8078;\n        font-size: 13px;\n        pointer-events: none;\n    }\n    .jewelry-quote-container .field-select-wrap select {\n        padding-right: 36px;\n        cursor: pointer;\n    }\n    .jewelry-quote-container .field-select-wrap select.empty {\n        color: #b0a89f;\n    }\n    .jewelry-quote-container .field-select-wrap select option {\n        color: #534A43;\n    }\n    .jewelry-quote-container .field-select-wrap select option[value=\"\"] {\n        color: #b0a89f;\n    }\n\n    /* ── Diamond Shape label row ── */\n    .jewelry-quote-container .shape-label {\n        font-size: 0.88rem;\n        color: #2c2522;\n        font-weight: 700;\n        margin-bottom: 14px;\n        display: flex;\n        align-items: center;\n        gap: 3px;\n    }\n    .jewelry-quote-container .shape-label .req { color: #c0392b; }\n\n    /* ── Diamond Shape Grid ── */\n    .jewelry-quote-container .shape-selector {\n        display: grid;\n        grid-template-columns: repeat(6, 1fr);\n        gap: 12px;\n        margin-bottom: 24px;\n    }\n    .jewelry-quote-container .shape-option {\n        background: #ffffff;\n        border: 1.5px solid #d0cfe8;\n        border-radius: 14px;\n        padding: 20px 8px 14px;\n        text-align: center;\n        cursor: pointer;\n        transition: all 0.18s;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        min-height: 130px;\n        position: relative;\n    }\n    .jewelry-quote-container .shape-option:hover {\n        border-color: #534A43;\n        background: #f5f2ef;\n        box-shadow: 0 0 0 1px #534A43;\n    }\n    .jewelry-quote-container .shape-option.selected {\n        border-color: #534A43;\n        background-color: #EFEAE3;\n        box-shadow: 0 0 0 1.5px #534A43;\n    }\n    .jewelry-quote-container .shape-option.selected::after {\n        content: '✓';\n        position: absolute;\n        top: 8px;\n        right: 8px;\n        width: 22px;\n        height: 22px;\n        background: #534A43;\n        color: #fff;\n        border-radius: 50%;\n        font-size: 0.72rem;\n        font-weight: 800;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        line-height: 22px;\n        text-align: center;\n    }\n    .jewelry-quote-container .shape-option img {\n        width: 64px;\n        height: 64px;\n        margin-bottom: 10px;\n        object-fit: contain;\n        opacity: 0.85;\n    }\n    .jewelry-quote-container .shape-name {\n        font-size: 0.72rem;\n        color: #3a3550;\n        font-weight: 600;\n        line-height: 1.2;\n    }\n    .jewelry-quote-container .shape-option.selected .shape-name {\n        color: #534A43;\n    }\n\n    /* ── File Upload ── */\n    .jewelry-quote-container .file-upload-wrapper {\n        border: 1.5px dashed #c4bdb5;\n        border-radius: 8px;\n        padding: 38px 20px;\n        text-align: center;\n        background: #faf8f6;\n        cursor: pointer;\n        transition: 0.2s;\n    }\n    .jewelry-quote-container .file-upload-wrapper:hover {\n        background: #EFEAE3;\n        border-color: #534A43;\n    }\n    .jewelry-quote-container .file-upload-text {\n        font-size: 0.82rem;\n        color: #6b6059;\n        line-height: 1.7;\n    }\n    .jewelry-quote-container .file-upload-text strong { font-weight: 600; }\n    .jewelry-quote-container .file-sub {\n        font-size: 0.7rem;\n        color: #a09890;\n        margin-top: 2px;\n        display: block;\n    }\n\n    /* ── Checkbox ── */\n    .jewelry-quote-container .checkbox-group {\n        display: flex;\n        align-items: center;\n        gap: 9px;\n        margin-top: 20px;\n    }\n    .jewelry-quote-container .checkbox-group input[type=\"checkbox\"] {\n        width: 15px;\n        height: 15px;\n        cursor: pointer;\n        flex-shrink: 0;\n        accent-color: #534A43;\n    }\n    .jewelry-quote-container .checkbox-group span {\n        font-size: 0.82rem;\n        color: #6b6059;\n    }\n\n    /* ── Buttons (Updated to Simple Bold Style with Thinner Font Border) ── */\n    .jewelry-quote-container .button-group {\n        display: flex;\n        gap: 20px; /* Spaced out to accommodate the drop shadow */\n        justify-content: center;\n        margin-top: 36px;\n        flex-wrap: wrap; /* Keeps buttons clean on small screens */\n    }\n    \n    .jewelry-quote-container button {\n        background-color: #D4B27E; /* Auvera Gold */\n        color: #ffffff;\n        border: 3px solid #1E1E1E; /* Auvera Charcoal */\n        border-radius: 999px; /* Pill shape */\n        box-shadow: -6px 6px 0px 0px #1E1E1E; /* Hard bottom-left shadow */\n        \n        /* Simple Bold Font Updates */\n        font-family: Arial, Helvetica, sans-serif; /* Clean, standard font */\n        font-weight: 900; /* Extra bold */\n        text-transform: uppercase;\n        letter-spacing: 1px;\n        font-size: 18px; \n        \n        padding: 14px 40px;\n        cursor: pointer;\n        transition: all 0.15s ease;\n        \n        /* White text with THIN charcoal outline */\n        -webkit-text-fill-color: #ffffff;\n        -webkit-text-stroke: 1px #1E1E1E; /* Reduced from 1.5px to 1px for a thinner line */\n        text-shadow: none;\n    }\n\n    .jewelry-quote-container button:hover {\n        background-color: #C8A46A; /* Auvera Gold Hover */\n        transform: translate(-3px, 3px);\n        box-shadow: -3px 3px 0px 0px #1E1E1E; /* Shadow shrinks on hover */\n    }\n\n    .jewelry-quote-container button:active {\n        transform: translate(-6px, 6px);\n        box-shadow: 0px 0px 0px 0px #1E1E1E; /* Button pushes in completely on click */\n    }\n\n    .jewelry-quote-container .btn-reset {\n        background-color: #EFEAE3; /* Secondary color for the reset button */\n    }\n    \n    .jewelry-quote-container .btn-reset:hover {\n        background-color: #e3dcd4;\n    }\n\n    @media (max-width: 700px) {\n        .jewelry-quote-container form { padding: 28px 20px 36px; }\n        .jewelry-quote-container .form-row { grid-template-columns: 1fr; gap: 16px; }\n        .jewelry-quote-container .shape-selector { grid-template-columns: repeat(3, 1fr); gap: 10px; }\n        .jewelry-quote-container .shape-option { min-height: 110px; }\n        .jewelry-quote-container .shape-option img { width: 50px; height: 50px; }\n        \n        .jewelry-quote-container button {\n            width: 100%; /* Full width buttons on mobile */\n            font-size: 16px;\n        }\n    }\n</style>\n\n<div class=\"jewelry-quote-container\">\n    <div class=\"form-wrapper\">\n        <div class=\"form-header\">\n            <h1>Jewelry Quote Request</h1>\n            <p>Get your custom jewelry quote today</p>\n        </div>\n\n        <form id=\"jewelryQuoteForm\">\n            <div class=\"section-title section-first\">Personal Information</div>\n\n            <div class=\"form-row\">\n                <div class=\"field\">\n                    <label for=\"jq-name\">Full Name <span class=\"req\">*</span></label>\n                    <input type=\"text\" id=\"jq-name\" placeholder=\"e.g. John Smith\" required>\n                </div>\n                <div class=\"field\">\n                    <label for=\"jq-email\">Email Address <span class=\"req\">*</span></label>\n                    <input type=\"email\" id=\"jq-email\" placeholder=\"e.g. john@example.com\" required>\n                </div>\n            </div>\n\n            <div class=\"form-row single\" style=\"margin-bottom:0;\">\n                <div class=\"field\">\n                    <label for=\"jq-phone\">Phone Number <span class=\"req\">*</span></label>\n                    <input type=\"tel\" id=\"jq-phone\" placeholder=\"+1 (555) 123-4567\" required>\n                </div>\n            </div>\n\n            <div class=\"section-title\">Jewelry Details</div>\n\n            <div class=\"form-row single\">\n                <div class=\"field\">\n                    <label for=\"jq-type\">Jewelry Type <span class=\"req\">*</span></label>\n                    <div class=\"field-select-wrap\">\n                        <select id=\"jq-type\" class=\"empty\" required onchange=\"handleSelect(this)\">\n                            <option value=\"\">Select jewelry type</option>\n                            <option>Ring</option>\n                            <option>Necklace</option>\n                            <option>Bracelet</option>\n                            <option>Earrings</option>\n                            <option>Pendant</option>\n                        </select>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"shape-label\">Diamond Shape <span class=\"req\">*</span>\n</div>\n            <div class=\"shape-selector\">\n                <div class=\"shape-option\" data-shape=\"Round\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Round.svg\" alt=\"Round\">\n                    <div class=\"shape-name\">Round</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Oval\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Oval.svg\" alt=\"Oval\">\n                    <div class=\"shape-name\">Oval</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Cushion\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Cushion.svg\" alt=\"Cushion\">\n                    <div class=\"shape-name\">Cushion</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Emerald\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Emerald.svg\" alt=\"Emerald\">\n                    <div class=\"shape-name\">Emerald</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Princess\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Princess.svg\" alt=\"Princess\">\n                    <div class=\"shape-name\">Princess</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Radiant\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Radiant.svg\" alt=\"Radiant\">\n                    <div class=\"shape-name\">Radiant</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Pear\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Pear.svg\" alt=\"Pear\">\n                    <div class=\"shape-name\">Pear</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Marquise\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Marquise.svg\" alt=\"Marquise\">\n                    <div class=\"shape-name\">Marquise</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Asscher\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Asscher.svg\" alt=\"Asscher\">\n                    <div class=\"shape-name\">Asscher</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Heart\">\n                    <img src=\"https://www.luvansh.com/images/diamond-shape/shape-Heart.svg\" alt=\"Heart\">\n                    <div class=\"shape-name\">Heart</div>\n                </div>\n                <div class=\"shape-option\" data-shape=\"Other\">\n                    <img src=\"https://res.cloudinary.com/doax9gift/image/upload/v1764323033/ivwv2xdv2rcaffmmuth7.jpg\" alt=\"Other\">\n                    <div class=\"shape-name\">Other</div>\n                </div>\n            </div>\n            <input type=\"hidden\" id=\"jq-shape-input\" required>\n\n            <div class=\"form-row single\">\n                <div class=\"field\">\n                    <label for=\"jq-carat\">Carat Weight <span class=\"req\">*</span></label>\n                    <div class=\"field-select-wrap\">\n                        <select id=\"jq-carat\" class=\"empty\" required onchange=\"handleSelect(this)\">\n                            <option value=\"\">Select carat weight</option>\n                            <option>0.50 ct</option>\n                            <option>0.75 ct</option>\n                            <option>1.00 ct</option>\n                            <option>1.50 ct</option>\n                            <option>2.00 ct</option>\n                            <option>3.00+ ct</option>\n                        </select>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"section-title\">Reference Image</div>\n\n            <div class=\"file-upload-wrapper\" id=\"jq-upload-zone\" onclick=\"document.getElementById('jq-file-input').click()\">\n                <div class=\"file-upload-text\">\n                    <strong>📷 Click to upload or drag & drop</strong>\n                    <span class=\"file-sub\">PNG, JPG, GIF up to 5MB</span>\n                </div>\n            </div>\n            <input type=\"file\" id=\"jq-file-input\" accept=\"image/*\" style=\"display:none;\">\n\n            <div class=\"section-title\">Additional Information</div>\n\n            <div class=\"field\">\n                <label for=\"jq-details\">Project Details <span class=\"req\">*</span></label>\n                <textarea id=\"jq-details\" placeholder=\"Describe your jewelry piece — style preferences, metal type, occasion, or any special requests...\" required></textarea>\n            </div>\n\n            <div class=\"checkbox-group\">\n                <input type=\"checkbox\" id=\"jq-newsletter\">\n                <span>Subscribe to our newsletter for exclusive offers</span>\n            </div>\n\n            <div class=\"button-group\">\n                <button type=\"submit\" class=\"btn-submit\">Submit Quote</button>\n                <button type=\"reset\" class=\"btn-reset\">Clear</button>\n            </div>\n        </form>\n    </div>\n</div>\n\n<script>\n    function handleSelect(sel) {\n        if (sel.value) {\n            sel.classList.remove('empty');\n        } else {\n            sel.classList.add('empty');\n        }\n    }\n\n    // Shape selector\n    document.querySelectorAll('.shape-option').forEach(opt => {\n        opt.addEventListener('click', function () {\n            document.querySelectorAll('.shape-option').forEach(s => s.classList.remove('selected'));\n            this.classList.add('selected');\n            document.getElementById('jq-shape-input').value = this.dataset.shape;\n        });\n    });\n\n    // File upload\n    const uploadZone = document.getElementById('jq-upload-zone');\n    const fileInput  = document.getElementById('jq-file-input');\n\n    uploadZone.addEventListener('dragover', e => {\n        e.preventDefault();\n        uploadZone.style.background = '#EFEAE3';\n        uploadZone.style.borderColor = '#534A43';\n    });\n    uploadZone.addEventListener('dragleave', () => {\n        uploadZone.style.background = '';\n        uploadZone.style.borderColor = '';\n    });\n    uploadZone.addEventListener('drop', e => {\n        e.preventDefault();\n        const file = e.dataTransfer.files[0];\n        if (file) showFile(file.name);\n        uploadZone.style.background = '';\n        uploadZone.style.borderColor = '';\n    });\n    fileInput.addEventListener('change', e => {\n        if (e.target.files[0]) showFile(e.target.files[0].name);\n    });\n    function showFile(name) {\n        uploadZone.innerHTML = `<div class=\"file-upload-text\"><strong>✅ ${name}</strong><span class=\"file-sub\">File selected</span></div>`;\n    }\n\n    // Reset\n    document.getElementById('jewelryQuoteForm').addEventListener('reset', () => {\n        document.querySelectorAll('.shape-option').forEach(s => s.classList.remove('selected'));\n        document.getElementById('jq-shape-input').value = '';\n        document.getElementById('jq-type').classList.add('empty');\n        document.getElementById('jq-carat').classList.add('empty');\n        uploadZone.innerHTML = `<div class=\"file-upload-text\"><strong>📷 Click to upload or drag & drop</strong><span class=\"file-sub\">PNG, JPG, GIF up to 5MB</span></div>`;\n    });\n\n    // Submit\n    document.getElementById('jewelryQuoteForm').addEventListener('submit', e => {\n        e.preventDefault();\n        alert('Quote request submitted! We will contact you shortly.');\n    });\n</script>",
