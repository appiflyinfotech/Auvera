    "1640249067965cb02d": {
      "type": "advanced-content",
      "settings": {
        "animation": "fade-up",
        "setwidth": "container",
        "text_color": "rgba(0,0,0,0)",
        "bgsection": "#ffffff",
        "rangebg": 0,
        "bgbefore": "rgba(0,0,0,0)",
        "e_size": "auto",
        "e_repeat": "no-repeat",
