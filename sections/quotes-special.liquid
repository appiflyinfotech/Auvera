{%-liquid
  assign image_size = section.settings.image_size
  assign paddingTop = ''
  case image_size
    when 'portrait'
    assign paddingTop = '120%'
    when 'square'
    assign paddingTop = '100%'
    when 'landscape'
    assign paddingTop = '75%'
    when 'wide'
    assign paddingTop = '56%'
  endcase
-%}
{% style %}
  .customstyle{{ section.id }}{
    --g-padding-s-top: {{ paddingTop }} ;
    background-color: {{ section.settings.bgsection }};
  }
  .customstyle{{ section.id }} .rating li svg{
    fill: {{ section.settings.color_rate }};
  }
  .customstyle{{ section.id }} .rating li.rated svg{
    fill: {{ section.settings.color_rated }};
  }
  .author-right .image-content__image-wrapper.portrait{
    padding-top: var(--g-padding-s-top) !important;
    overflow: hidden;
  }
  .author-right .image-content__image-wrapper.square{
    padding-top: var(--g-padding-s-top) !important;
    overflow: hidden;
  }
  .author-right .image-content__image-wrapper.landscape{
    padding-top: var(--g-padding-s-top) !important;
    overflow: hidden;
  }
  .author-right .image-content__image-wrapper.wide{
    padding-top: var(--g-padding-s-top) !important;
    overflow: hidden;
  }
  .author-right .image-content__image-wrapper.portrait img,.author-right .image-content__image-wrapper.square img,.author-right .image-content__image-wrapper.landscape img,.author-right .image-content__image-wrapper.wide img{
    height: 100%;
    object-fit: cover;
  }
  .quote-product-item{
    position:absolute;
    bottom:1rem;
    left:1rem;
    max-width:300px;
    z-index: 10;
  }
  .quote-product-item .product-card{
    display:flex;
    padding:1rem;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .quote-product-item .product-card__image-wr{
    width: 72px;
    flex: 0 0 72px;
    margin-right: 1.5rem;
  }
  .quote-product-item .product-card__info{
    padding: 0!important;
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  /* --- PILL BUTTON DESIGN FOR PRODUCT ITEM --- */
  .customstyle{{ section.id }} .quote-product-item .js-btn-quickview,
  .customstyle{{ section.id }} .quote-product-item .btn {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    background-color: #c5a67a !important; 
    color: #ffffff !important;
    border: 2px solid #111111 !important;
    border-radius: 50px !important; 
    padding: 6px 18px !important;
    font-family: 'Barlow Condensed', sans-serif !important;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.05em;
    box-shadow: -3px 3px 0px 0px #111111;
    text-decoration: none !important;
    margin-top: 8px;
    transition: all 0.1s ease;
    line-height: 1.2;
  }

  .customstyle{{ section.id }} .quote-product-item .js-btn-quickview:active {
    transform: translate(-2px, 2px);
    box-shadow: -1px 1px 0px 0px #111111;
  }

  /* --- PILL DESIGN FOR SLIDER ARROWS --- */
  .customstyle{{ section.id }} .slick-arrow {
    background-color: #ffffff !important;
    color: #111111 !important;
    border: 2px solid #111111 !important;
    border-radius: 50% !important;
    width: 45px !important;
    height: 45px !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
    box-shadow: -3px 3px 0px 0px #111111;
    transition: all 0.2s ease;
    z-index: 5;
    opacity: 1 !important;
  }

  .customstyle{{ section.id }} .slick-arrow:before {
    color: #111111 !important;
    font-size: 20px;
  }

  .customstyle{{ section.id }} .slick-arrow:hover {
    background-color: #f8f8f8 !important;
  }

  .customstyle{{ section.id }} .slick-arrow:active {
    transform: translate(-2px, 2px);
    box-shadow: -1px 1px 0px 0px #111111;
  }

  /* Positioning Arrows */
  .customstyle{{ section.id }} .slick-prev { left: -25px; }
  .customstyle{{ section.id }} .slick-next { right: -25px; }

  @media (max-width: 767px) {
    .customstyle{{ section.id }} .slick-arrow { display: none !important; }
  }

  .product-dark.quote-product-item .product-card{
    background:rgba(var(--g-color-heading-rgb),0.9);
    transition:background 0.3s ease;
  }
  .product-dark.quote-product-item .product-card:hover{
    background:rgba(var(--g-color-heading-rgb),1);
  }
  .product-dark.quote-product-item .product-card__info{
    background:transparent;
  }
  .product-dark .product-card__info{
    --g-color-heading:white;
    --g-color-heading-rgb:255,255,255;
    --color-body-text-rgb:255,255,255;
  }
{% endstyle %}

{%- render 'style-section' -%}

<div class="customstyle{{ section.id }} ">
  <div class="{{ section.settings.setwidth }}">
    <div class="section-block">
      {%- render 'section-heading' -%}
      {%- if section.blocks.size > 0 -%}
      <div class="quotes-wrapper dots-negative quotes-2" > 
        <div class="quotes-slider row" id="Quotes-{{ section.id }}" 
             data-rows="{{ section.settings.rows }}"
             data-slidesToShow="1"
             data-slidestoscroll="1"
             data-arrows="{{ section.settings.arrows }}"
             data-dots="{{ section.settings.dots }}" 
             data-draggable="{{ section.settings.draggable }}" 
             data-infinite="{{ section.settings.infinite }}" 
             data-section-id="{{ section.id }}" 
             data-section-type="slickCarousels">
          {%- for block in section.blocks -%}
          <div class="quote__slide-wrapper carousel__slide-wrapper--{{ block.id }}" {{ block.shopify_attributes }}>
            <div class="quote__slide">
              <div class="quote-wrap row align-items-center">
                <div class="col-12 col-md-6" data-aos="{{ section.settings.animation }}" data-aos-duration="500">
                    <div class="pb-5 px-3 px-lg-0">
                    {%- if block.settings.title != blank -%}
                        <div class="subtop pb-3">
                        {{ block.settings.title }}
                        </div>
                        {%- endif -%}
                        <div class="pt-3 pb-3">
                          {%- if block.settings.rate > 0 -%}
                            <ul class="rating mb-3">
                              {%- for i in (1..5) -%}
                                {%- assign iMax = block.settings.rate -%}
                                {%- if i <= iMax -%}
                                <li class="rated">
                                  <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                                </li>
                                    {%- else -%}
                                <li>
                                  <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                                </li>
                                  {%- endif -%}
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                          <div class="{{ section.settings.size_text }}">{{ block.settings.quote }}</div>
                        </div>
                        <div class=" font-family-2 mt-1">{{ block.settings.author }}</div>
                        {%- if block.settings.info != blank -%}
                        <i class="small">{{ block.settings.info }}</i>
                    {%- endif -%}
                  </div>
                </div>
                <div class="col-12 col-md-6" data-aos="{{ section.settings.animation }}" data-aos-duration="1500">
                    
                        <div class="pl-lg-5">
                            <div class="position-relative">
                            <div class="position-relative overflow-hidden author-right ">
                              {%- if block.settings.avatar != blank -%}
                              <div class="image-content__image-wrapper {{ image_size }}" style="padding-top:{{ 1 | divided_by: block.settings.avatar.aspect_ratio | times: 100 }}%;">
                              {% assign image = block.settings.avatar %}
                                <img
                                  srcset="
                                    {%- if image.width >= 165 -%}{{ image | image_url: width: 165 }} 165w,{%- endif -%}
                                    {%- if image.width >= 360 -%}{{ image | image_url: width: 360 }} 360w,{%- endif -%}
                                    {%- if image.width >= 533 -%}{{ image | image_url: width: 533 }} 533w,{%- endif -%}
                                    {%- if image.width >= 720 -%}{{ image | image_url: width: 720 }} 720w,{%- endif -%}
                                    {%- if image.width >= 940 -%}{{ image | image_url: width: 940 }} 940w,{%- endif -%}
                                    {%- if image.width >= 1066 -%}{{ image | image_url: width: 1066 }} 1066w,{%- endif -%}
                                    {{ image | image_url }} {{ image.width }}w
                                  "
                                  src="{{ image | image_url: width: 720 }}"
                                  sizes="(min-width: 990px) 50vw, 100vw"
                                  alt="{{ image.alt | escape }}"
                                  class="image-content__image lazyload scale-in"
                                  data-sizes="auto"
                                  data-aspectratio="{{ image.aspect_ratio }}"
                                  loading="lazy"
                                  width="{{ image.width }}"
                                  height="{{ image.height }}"
                                >
                              </div>
                              {%- else -%}
                              <div class="image-content__image">
                                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                              </div>
                            {%- endif -%}
                            </div>
                            {%- if block.settings.product_item != blank -%}
                              <div class="quote-product-item product-{{ block.settings.product_style }}">
                              {% render 'product-grid-buywith', product: block.settings.product_item, firstimage: false, enablqv: true %}
                              </div>
                            {%- endif -%}
                            </div>
                        </div>
                </div>
              </div>
            </div>
          </div>
          {%- endfor -%}
        </div>
      </div>
      {%- endif -%}
  
      {%- if section.blocks.size == 0 -%}
      {%- render 'no-blocks' -%}
      {%- endif -%}
    </div>
  </div>
  </div>
  
{% schema %}
{
  "name": "Testimonials Split",
  "class": "index-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "options": [
        { "value": "", "label": "None" },
        { "value": "fade", "label": "Fade" },
        { "value": "fade-up", "label": "Fade Up" },
        { "value": "fade-down", "label": "Fade Down" },
        { "value": "fade-left", "label": "Fade Left" },
        { "value": "fade-right", "label": "Fade Right" },
        { "value": "zoom-in", "label": "Zoom In" }
      ],
      "label": "Select Animation"
    },
    {
      "type": "select",
      "id": "setwidth",
      "label": "Full Width",
      "default": "container",
      "options": [
        { "value": "container", "label": "Box" },
        { "value": "container-fluid", "label": "Container Fluid" },
        { "value": "full", "label": "Full" }
      ]
    },
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Section",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "title_top",
      "label": "Sub Title Top",
      "default": "Sub Title Top"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "User reviews"
    },
    {
      "type": "textarea",
      "id": "des",
      "label": "HTML / Description"
    },
    {
      "type": "select",
      "id": "align-heading",
      "label": "Align Heading",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "color_rate",
      "label": "Color Rate",
      "default": "#f1f1f1"
    },
    {
      "type": "color",
      "id": "color_rated",
      "label": "Color Rated",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Size Image"
    },
    {
      "type": "select",
      "id": "image_size",
      "options": [
        { "value": "auto", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait (2:3)" },
        { "value": "landscape", "label": "Landscape (4:3)" },
        { "value": "wide", "label": "Wide (16:9)" },
        { "value": "square", "label": "Square (1:1)" }
      ],
      "default": "auto",
      "label": "Image ratio"
    },
    {
      "type": "select",
      "id": "size_text",
      "default": "p",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p", "label": "Body" }
      ],
      "label": "Text Size"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "arrows",
      "label": "Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "draggable",
      "label": "Draggable",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "infinite",
      "label": "Infinite",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding "
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Padding Section",
      "default": "0px 0px 0px 0px"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Padding Section Mobile",
      "default": "40px 0px 40px 0px"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        { "type": "text", "id": "title", "label": "Comment", "default": "Comment" },
        { "type": "textarea", "id": "quote", "label": "Text", "default": "Add customer reviews." },
        { "type": "range", "id": "rate", "min": 0, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "text", "id": "author", "label": "Author", "default": "Author's name" },
        { "type": "text", "id": "info", "label": "Author's info" },
        { "type": "image_picker", "id": "avatar", "label": "Image" },
        { "type": "product", "id": "product_item", "label": "Product" },
        {
          "type": "select",
          "id": "product_style",
          "default": "light",
          "options": [
            { "value": "light", "label": "Light" },
            { "value": "dark", "label": "Dark" }
          ],
          "label": "Product Style"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Split",
      "category": "Text",
      "blocks": [
        { "type": "quote" },
        { "type": "quote" }
      ]
    }
  ]
}
{% endschema %}